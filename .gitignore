# ----------------------------------------------------------------------------
# Allocare Intelligence Hub - Global .gitignore
# ----------------------------------------------------------------------------

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Local Environment & Config
.env
.env.*
.env.json
!.env.json.example
.fvm/
.firebase/
firebase_options.dart

# Firebase Flutter config files (Machine-specific)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# IDE Related
*.iml
*.ipr
*.iws
.idea/
.vscode/
.history/
*.sublime-project
*.sublime-workspace

# Flutter/Dart/Pub Related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
/build/
/coverage/
.packages

# Web Related
build/web/
.dart_tool/build/

# Android Studio artifacts
/android/app/debug
/android/app/profile
/android/app/release
/android/local.properties
/android/.gradle/
android/app/src/main/res/values/google-services.xml

# iOS/Xcode artifacts
**/DerivedData/
**/*.xcuserstate
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec

# Symbolication & Obfuscation
app.*.symbols
app.*.map.json

# Tool-specific (Antigravity & AI)
.antigravity/
.gemini/
*.temp
*.tmp
node_modules/
package-lock.json

# ----------------------------------------------------------------------------
# End of .gitignore
# ----------------------------------------------------------------------------
